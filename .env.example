# PostgreSQL
POSTGRES_USER=casasim
POSTGRES_PASSWORD=changeme
POSTGRES_DB=casasim
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=Host=localhost;Port=5432;Database=casasim;Username=casasim;Password=changeme

# ConnectionStrings (Npgsql)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=casasim;Username=casasim;Password=changeme

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Admin dashboard API key (production: set a strong random value)
AdminSettings__ApiKey=

# Serilog
SERILOG__MINIMUMLEVEL=Information
