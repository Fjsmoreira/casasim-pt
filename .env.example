# PostgreSQL
POSTGRES_USER=casasim
POSTGRES_PASSWORD=changeme
POSTGRES_DB=casasim
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=Host=localhost;Port=5432;Database=casasim;Username=casasim;Password=changeme

# ConnectionStrings (Npgsql)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=casasim;Username=casasim;Password=changeme

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Admin dashboard API key (production: set a strong random value)
AdminSettings__ApiKey=

# OpenTelemetry
# Set to your OTLP endpoint to enable distributed tracing and metrics export.
# leave empty (default) for no-op local dev without observability.
# With the observability compose profile: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional: headers for OTLP export (e.g. "Authorization=Bearer mykey")
# OTEL_EXPORTER_OTLP_HEADERS=

# Serilog
SERILOG__MINIMUMLEVEL=Information
